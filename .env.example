# ============================================================================
# Node.js & Application
# ============================================================================
NODE_ENV=development
PORT=3000

# ============================================================================
# Redis Configuration (Cache Layer L2)
# ============================================================================
REDIS_HOST=filestorage_redis
REDIS_PORT=6379

# ============================================================================
# RabbitMQ Configuration (Archival Job Queue)
# ============================================================================
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_URL=amqp://guest:guest@filestorage_rabbitmq:5672

# ============================================================================
# Hot Storage (Local Filesystem)
# ============================================================================
# Absolute path inside the container where hot files are stored
HOT_STORAGE_PATH=/hot-storage

# ============================================================================
# MinIO Configuration (Archival Storage)
# ============================================================================
MINIO_ENDPOINT=filestorage_minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_ARCHIVE_BUCKET=filestorage-archive

# ============================================================================
# Archival Policy
# ============================================================================
# Time in seconds before a hot file is eligible for archival
# Example: 86400 = 1 day, 604800 = 7 days
ARCHIVE_AFTER_SECONDS=604800

# Cron expression for archival scheduler (NestJS @nestjs/schedule format)
# Format: second minute hour day-of-month month day-of-week
# Default: "0 * * * * *" = every minute at second 0
ARCHIVAL_CRON=0 * * * * *

# ============================================================================
# File Upload Configuration
# ============================================================================
# Maximum file size in bytes (default: 100 MB = 104857600)
UPLOAD_MAX_SIZE_BYTES=104857600